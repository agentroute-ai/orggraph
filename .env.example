# Copy to .env and edit as needed. .env is gitignored.

# =========================================================================
# Databases (run in Docker everywhere — Mac, DGX, HPC)
# =========================================================================
POSTGRES_DB=orggraph
POSTGRES_USER=orggraph
POSTGRES_PASSWORD=orggraph2026
POSTGRES_PORT=5432

NEO4J_USER=neo4j
NEO4J_PASSWORD=orggraph2026
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# =========================================================================
# LLM serving — pick ONE of the three modes below
# =========================================================================

# --- Mode A: Mac dev (Ollama running natively, Metal-accelerated) ---------
# Install: `brew install ollama && ollama serve &`
# Pull models:
#   ollama pull embeddinggemma:300m        # ~300MB
#   ollama pull gemma3:4b                  # ~3GB  (dev stand-in for 31B)
# Code reads OPENAI_BASE_URL — Ollama is OpenAI-compatible at /v1.
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
INFERENCE_MODEL=gemma3:4b
EMBED_MODEL=embeddinggemma:300m

# --- Mode B: DGX Spark (Docker vLLM via `--profile dgx`) ------------------
# OPENAI_BASE_URL=http://localhost:8000/v1
# OPENAI_API_KEY=EMPTY
# INFERENCE_MODEL=google/gemma-4-31B-it
# EMBED_MODEL=google/embeddinggemma-300m
# VLLM_INFERENCE_PORT=8000
# VLLM_EMBED_PORT=8001
# HF_TOKEN=hf_xxxxxxxxxxxxx   # accept license at https://huggingface.co/google/gemma-4-31B-it

# --- Mode C: CSCS Alps (HPC, no internet) ---------------------------------
# vLLM launched via SLURM job, models pre-staged in $STORE
# OPENAI_BASE_URL=http://$(hostname):8000/v1
